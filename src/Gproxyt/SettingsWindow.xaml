<ui:FluentWindow x:Class="Gproxyt.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="设置"
                 Width="304"
                 MinWidth="304"
                 MaxWidth="304"
                 Height="390"
                 ResizeMode="NoResize"
                 WindowStyle="None"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 WindowCornerPreference="Round"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="DragWindow">
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="设置" />
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource HeaderIconButtonStyle}"
                    AutomationProperties.Name="关闭"
                    Click="Cancel">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="21" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="24,16,24,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="代理 URL" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="ChatGPT 使用的代理地址" />
                <ui:TextBox x:Name="ProxyUrlTextBox"
                            Height="38"
                            Margin="0,10,0,0"
                            AutomationProperties.Name="代理 URL"
                            VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="开机自启" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="登录 Windows 后自动启动 ChatGPT" />
                <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                                 Margin="0,10,0,0"
                                 HorizontalAlignment="Left"
                                 Cursor="Hand"
                                 AutomationProperties.Name="开机自启" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <ui:Button Margin="0,0,10,0"
                           Cursor="Hand"
                           AutomationProperties.Name="取消"
                           Appearance="Secondary"
                           Content="取消"
                           Click="Cancel" />
                <ui:Button Cursor="Hand"
                           Appearance="Primary"
                           AutomationProperties.Name="保存"
                           Content="保存"
                           Click="Save" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
