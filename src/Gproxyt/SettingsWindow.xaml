<ui:FluentWindow x:Class="Gproxyt.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:Gproxyt"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding [Settings], Source={x:Static local:AppLocalization.Current}}"
                 Width="420"
                 MinWidth="360"
                 Height="540"
                 ResizeMode="NoResize"
                 WindowStyle="None"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 WindowCornerPreference="Round"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="DragWindow">
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="{Binding [Settings], Source={x:Static local:AppLocalization.Current}}" />
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource HeaderIconButtonStyle}"
                    AutomationProperties.Name="{Binding [Close], Source={x:Static local:AppLocalization.Current}}"
                    Click="Cancel">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="21" />
            </Button>
        </Grid>

        <Border x:Name="SettingsPanel"
                Grid.Row="1"
                Margin="16,8,16,16"
                Padding="20"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding [ProxyUrl], Source={x:Static local:AppLocalization.Current}}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="{Binding [ProxyUrlDescription], Source={x:Static local:AppLocalization.Current}}"
                           TextWrapping="Wrap" />
                <ui:TextBox x:Name="ProxyUrlTextBox"
                            Height="38"
                            Margin="0,10,0,0"
                            AutomationProperties.Name="{Binding [ProxyUrl], Source={x:Static local:AppLocalization.Current}}"
                            VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding [StartWithWindows], Source={x:Static local:AppLocalization.Current}}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="{Binding [StartWithWindowsDescription], Source={x:Static local:AppLocalization.Current}}"
                           TextWrapping="Wrap" />
                <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                                 Margin="0,10,0,0"
                                 HorizontalAlignment="Left"
                                 Cursor="Hand"
                                 AutomationProperties.Name="{Binding [StartWithWindows], Source={x:Static local:AppLocalization.Current}}" />
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding [Language], Source={x:Static local:AppLocalization.Current}}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="{Binding [LanguageDescription], Source={x:Static local:AppLocalization.Current}}"
                           TextWrapping="Wrap" />
                <ComboBox x:Name="LanguageComboBox"
                          Height="38"
                          Margin="0,10,0,0"
                          AutomationProperties.Name="{Binding [Language], Source={x:Static local:AppLocalization.Current}}"
                          DisplayMemberPath="NativeName"
                          SelectedValuePath="Name" />
            </StackPanel>

            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <ui:Button Margin="0,0,10,0"
                           Cursor="Hand"
                           AutomationProperties.Name="{Binding [Cancel], Source={x:Static local:AppLocalization.Current}}"
                           Appearance="Secondary"
                           Content="{Binding [Cancel], Source={x:Static local:AppLocalization.Current}}"
                           Click="Cancel" />
                <ui:Button Cursor="Hand"
                           Appearance="Primary"
                           AutomationProperties.Name="{Binding [Save], Source={x:Static local:AppLocalization.Current}}"
                           Content="{Binding [Save], Source={x:Static local:AppLocalization.Current}}"
                           Click="Save" />
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
