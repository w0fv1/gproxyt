<ui:FluentWindow x:Class="Gproxyt.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:i18n="http://schemas.lepo.co/i18n/2022/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{i18n:StringLocalizer Settings}"
                 Width="420"
                 MinWidth="360"
                 Height="430"
                 ResizeMode="NoResize"
                 WindowStyle="None"
                 ExtendsContentIntoTitleBar="True"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 WindowCornerPreference="Round"
                 WindowBackdropType="Mica"
                 Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="DragWindow">
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="{i18n:StringLocalizer Settings}" />
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource HeaderIconButtonStyle}"
                    AutomationProperties.Name="{i18n:StringLocalizer Close}"
                    Click="Cancel">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="21" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="24,16,24,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{i18n:StringLocalizer ProxyUrl}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="{i18n:StringLocalizer ProxyUrlDescription}"
                           TextWrapping="Wrap" />
                <ui:TextBox x:Name="ProxyUrlTextBox"
                            Height="38"
                            Margin="0,10,0,0"
                            AutomationProperties.Name="{i18n:StringLocalizer ProxyUrl}"
                            VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Text="{i18n:StringLocalizer StartWithWindows}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Text="{i18n:StringLocalizer StartWithWindowsDescription}"
                           TextWrapping="Wrap" />
                <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                                 Margin="0,10,0,0"
                                 HorizontalAlignment="Left"
                                 Cursor="Hand"
                                 AutomationProperties.Name="{i18n:StringLocalizer StartWithWindows}" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <ui:Button Margin="0,0,10,0"
                           Cursor="Hand"
                           AutomationProperties.Name="{i18n:StringLocalizer Cancel}"
                           Appearance="Secondary"
                           Content="{i18n:StringLocalizer Cancel}"
                           Click="Cancel" />
                <ui:Button Cursor="Hand"
                           Appearance="Primary"
                           AutomationProperties.Name="{i18n:StringLocalizer Save}"
                           Content="{i18n:StringLocalizer Save}"
                           Click="Save" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
