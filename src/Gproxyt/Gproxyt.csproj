<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>gproxyt</AssemblyName>
    <RootNamespace>Gproxyt</RootNamespace>
    <Product>GProxyT</Product>
    <Version>1.4.0-stable</Version>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <ApplicationIcon>Assets\gproxyt.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Serilog" Version="4.4.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageReference Include="WPF-UI" Version="4.3.0" />
    <ProjectReference Include="..\Gproxyt.Core\Gproxyt.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\Strings.*.json" WithCulture="false" />
    <Resource Include="Assets\gproxyt.ico" />
    <Resource Include="Assets\gproxyt.png" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Gproxyt.Windows.Tests" />
  </ItemGroup>
</Project>
